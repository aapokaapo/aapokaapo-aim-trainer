# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Halo Infinite / Azure OAuth credentials
# ---------------------------------------------------------------------------
# Used by both the /import-matches/ endpoint AND the background updater.
# Follow https://acurtis166.github.io/SPNKr/getting-started/ to create an
# Azure AD app and obtain these values.
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_REFRESH_TOKEN=your_azure_refresh_token_here
REDIRECT_URI=https://localhost

# ---------------------------------------------------------------------------
# Microsoft OAuth / Xbox "Add player" flow
# ---------------------------------------------------------------------------
# PUBLIC_BASE_URL is used to build the OAuth redirect URI automatically:
#   Redirect URI = {PUBLIC_BASE_URL}/auth/microsoft/callback
#
# Local development:
#   PUBLIC_BASE_URL=http://127.0.0.1:8000
#
# Production:
#   PUBLIC_BASE_URL=https://aimtrainer.aapokaapostats.site
#
# Make sure the value you set here is registered as an allowed redirect URI
# in your Azure app registration under
#   Azure Portal → App registrations → <your app> → Authentication → Redirect URIs
#
# Add BOTH URIs if you want the same app registration to work in dev and prod:
#   http://127.0.0.1:8000/auth/microsoft/callback
#   https://aimtrainer.aapokaapostats.site/auth/microsoft/callback
#
# The Azure app must request the "XboxLive.signin" delegated permission
# (found under APIs my organization uses → Xbox Live → XboxLive.signin).
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Fallback / legacy: static Spartan & clearance tokens.
# These are only used by the manual /import-matches/ endpoint when the Azure
# OAuth vars above are NOT set.  Prefer the Azure vars for production.
SPARTAN_TOKEN=your_spartan_token_here
CLEARANCE_TOKEN=your_clearance_token_here

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Optional: override the SQLite database path (default: sqlite:///matches.db)
# DATABASE_URL=sqlite:///matches.db

# ---------------------------------------------------------------------------
# Background updater configuration
# ---------------------------------------------------------------------------
# How often (in seconds) to run the periodic match-update cycle.
# Default: 300 (= 5 minutes)
UPDATE_INTERVAL_SECONDS=300

# Fallback game_variant_category integer to filter matches by when a player
# has no per-player gamemode stored.  Inspect the match_info.game_variant_category
# field in your first manual import to find the right value for your game type.
# Default: 9
DEFAULT_GAMEMODE=9
