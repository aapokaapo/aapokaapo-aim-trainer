# Copy this file to .env and fill in your values.

# Halo Infinite authentication tokens (manual override – not needed when using
# the Azure OAuth flow below to obtain tokens at runtime).
SPARTAN_TOKEN=your_spartan_token_here
CLEARANCE_TOKEN=your_clearance_token_here

# Azure OAuth credentials for the automatic Spartan token flow.
# When SPARTAN_TOKEN is absent, the application uses these values to obtain
# a Spartan token at runtime via spartan_auth.py.
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_REFRESH_TOKEN=your_azure_refresh_token_here
REDIRECT_URI=your_redirect_uri_here

# Optional: override the SQLite database path (default: sqlite:///matches.db)
# DATABASE_URL=sqlite:///matches.db
